# To learn more about .editorconfig see https://aka.ms/editorconfigdocs
root = true

# All files
[*]
indent_style = tab

[*.cs]
# IDE0063: Use simple 'using' statement
csharp_prefer_simple_using_statement = false:silent

# CS1574: XML comment has cref attribute that could not be resolved
dotnet_diagnostic.CS1574.severity = none

# IDE0057: Use range operator
csharp_style_prefer_range_operator = true:silent

# IDE0066: Convert switch statement to expression
csharp_style_prefer_switch_expression = false:silent

csharp_using_directive_placement = inside_namespace

# I don't prefer primary constructors in general.
dotnet_diagnostic.IDE0290.severity = none

# Using LibraryImportAttribute requires unsafe code to be allowed for the whole assembly.
dotnet_diagnostic.SYSLIB1054.severity = none

dotnet_diagnostic.CA1062.severity = none
dotnet_diagnostic.CA1303.severity = none
dotnet_diagnostic.CA1304.severity = none
dotnet_diagnostic.CA1305.severity = none
